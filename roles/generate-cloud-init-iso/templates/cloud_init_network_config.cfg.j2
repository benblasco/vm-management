# Network Config v2 — pass to cloud-localds as --network-config, not as user-data.
#
# Generate a per-VM seed ISO (replace MAC, IP, gateway, and DNS as needed):
#
#   cloud-localds -v myvm-seed.iso \
#     files/generic_vm/cloud_init_rhis.cfg \
#     --network-config files/cloud_init_static_ip_example.cfg
#
# Find the VM MAC after defining the domain (before or after first boot):
#
#   virsh dumpxml myvm.nuc.lan | grep -i mac
#
# Copy the seed ISO to the hypervisor path used by libvirt-newvm.yml
# (default: /var/lib/libvirt/images/) and deploy with:
#
#   ansible-playbook libvirt-newvm.yml --ask-become-pass \
#     -e "cloud_init_seed_iso=myvm-seed.iso" \
#     -e "vm_host_network=vm-network-vlan140"
#
version: 2
ethernets:
  nic0:
    match:
      macaddress: "{{ vm_mac_address }}"
    addresses:
      - {{ vm_ip_address }}/{{ vm_ip_prefix }}
    # routes:
    #   - to: default
    #     via: {{ vm_ip_gateway }}
    gateway4: {{ vm_ip_gateway }}
    nameservers:
      addresses:
{% set ns_list = vm_ip_nameservers if vm_ip_nameservers is not string else (vm_ip_nameservers | from_yaml) %}
{% for ns in ns_list %}
        - {{ ns }}
{% endfor %}
      search:
        - {{ vm_domain }}
